* text=auto

# Unix-first scripts and text formats should check out with LF.
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf
*.xsd   text eol=lf

# Windows-native scripts should check out with CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Obvious binary and archive formats should not be treated as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
